  <%- layout('layouts/boilerplate') %>
 

<div class="row mt-3">
    <div class="col-8 offset-2">
        <!-- <br> -->
           <h3 class="">Create New Listing</h3>
    <form 
    method="POST" 
    action="/listings" 
    novalidate 
    class="needs-validation"
    enctype="multipart/form-data"
    >
     <div class="mb-2">
       <label 
       for="title" 
       class="form-label">Title</label>
       <input 
       name="listing[title]" 
        placeholder="enter title" 
        type="text" 
        class="form-control" 
        required>
         <div class="invalid-feedback">Please enter title</div>
     </div>

        <div class="mb-2">
            <label for="description" 
            class="form-label">Description</label>
            <input 
            name="listing[description]" 
            placeholder="Description" 
            type="text" 
            class="form-control"
            required
            >
             <div class="invalid-feedback">Description required</div>
        </div>

        <div class="mb-2">
            <label 
             for="image" 
             class="form-label">Upload Image</label>
            <input 
             name="image" 
             type="file" 
             class="form-control"
             required
             >
       
      <div class="row">

         <div class="mb-2 col-md-4">
            <label for="price" 
            class="form-label">Price</label>
            <input 
            name="listing[price]" 
            placeholder="enter price" 
            type="number" 
            class="form-control" 
            required
            >
            <div class="invalid-feedback">Please enter a valid price</div>
        </div>

        <div class="mb-2 col-md-8">
             <label 
             for="country" 
             class="form-label">Country</label>
              <input 
              name="listing[country]" 
              placeholder="enter country name" 
              type="text" 
              class="form-control"
              required
              >
               <div class="invalid-feedback">Please enter a valid country name</div>
        </div>
      </div>
      <div 
      class="mb-4">
         <label 
         for="location" 
         class="form-label">Location</label>
         <input 
         name="listing[location]" 
         placeholder="enter location" 
         type="text" 
         class="form-control" 
         required
         >
          <div class="invalid-feedback">Please enter valid location</div>
       </div>
       
        <button class="btn btn-dark  mb-4  add-btn">Add</button>
        
    </form>
    </div>
</div>